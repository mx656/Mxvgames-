<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>💎 Crystal Tap - MXV Games</title>
    <style>
        :root {
            --bg: #0a0a1a; --panel: #12122a; --accent: #a855f7; --accent2: #6366f1;
            --gold: #f59e0b; --text: #e2e8f0; --text2: #cbd5e1; --success: #22c55e;
            --card: #1a1a3e; --border: #2a2a5a;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: var(--bg);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; overflow-x: hidden; user-select: none;
            -webkit-tap-highlight-color: transparent;
            background: radial-gradient(ellipse at center, #0f0f2e 0%, #060618 60%, #020210 100%);
            padding: 15px;
        }
        .game-container { width:100%; max-width:500px; display:flex; flex-direction:column; align-items:center; gap:16px; }
        .back-btn {
            align-self:flex-start; background:#1a1a3e; border:1px solid #2a2a5a; color:#e2e8f0;
            padding:10px 18px; border-radius:25px; cursor:pointer; font-weight:600; letter-spacing:1px;
            transition:all 0.2s; font-size:0.85rem; text-decoration:none; display:inline-flex; align-items:center; gap:6px;
        }
        .back-btn:hover { background:#2a2a5a; border-color:#a855f7; box-shadow:0 0 20px rgba(168,85,247,0.3); }
        .stats-bar { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; width:100%; }
        .stat-card {
            background:var(--card); border:1px solid var(--border); border-radius:16px;
            padding:14px 20px; text-align:center; min-width:90px; flex:1;
            box-shadow:0 4px 20px rgba(0,0,0,0.3);
        }
        .stat-label { font-size:0.7rem; text-transform:uppercase; letter-spacing:2px; color:var(--text2); margin-bottom:4px; }
        .stat-value { font-size:1.5rem; font-weight:700; color:#fff; text-shadow:0 0 20px rgba(255,255,255,0.3); }
        .stat-value.gold { color:var(--gold); text-shadow:0 0 20px rgba(245,158,11,0.4); }
        .crystal-wrapper { position:relative; cursor:pointer; margin:10px 0; }
        .crystal-wrapper:active { transform:scale(0.92); }
        .crystal-glow {
            position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
            width:180px; height:180px; border-radius:50%;
            background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, rgba(99,102,241,0.2) 40%, transparent 70%);
            pointer-events:none; animation:pulseGlow 2s ease-in-out infinite; z-index:0;
        }
        @keyframes pulseGlow {
            0%,100% { transform:translate(-50%,-50%) scale(1); opacity:0.7; }
            50% { transform:translate(-50%,-50%) scale(1.3); opacity:1; }
        }
        .crystal {
            position:relative; z-index:1; width:160px; height:160px;
            filter:drop-shadow(0 0 40px rgba(168,85,247,0.6)) drop-shadow(0 0 80px rgba(99,102,241,0.3));
            animation:crystalFloat 3s ease-in-out infinite;
        }
        @keyframes crystalFloat {
            0%,100% { transform:translateY(0); }
            50% { transform:translateY(-12px); }
        }
        .crystal svg { width:100%; height:100%; }
        .combo-text { text-align:center; font-size:0.75rem; color:#f59e0b; font-weight:600; letter-spacing:1px; min-height:18px; }
        .combo-bar-container { width:100%; height:6px; background:#1a1a3e; border-radius:10px; overflow:hidden; }
        .combo-bar-fill { height:100%; background:linear-gradient(90deg,#6366f1,#a855f7,#f59e0b); border-radius:10px; transition:width 0.1s; width:0%; }
        .float-text {
            position:fixed; pointer-events:none; z-index:100; font-weight:700; color:#fff; font-size:1.2rem;
            text-shadow:0 0 10px rgba(168,85,247,0.8); animation:floatAway 1s ease-out forwards; white-space:nowrap;
        }
        @keyframes floatAway {
            0% { opacity:1; transform:translateY(0) scale(1); }
            100% { opacity:0; transform:translateY(-120px) scale(1.4); }
        }
        .shop-panel { background:var(--card); border:1px solid var(--border); border-radius:20px; padding:16px; width:100%; box-shadow:0 8px 40px rgba(0,0,0,0.4); }
        .shop-title { font-size:1rem; font-weight:700; color:#fff; letter-spacing:1px; text-align:center; margin-bottom:12px; text-transform:uppercase; }
        .shop-items { display:flex; flex-direction:column; gap:6px; max-height:300px; overflow-y:auto; padding-right:4px; }
        .shop-items::-webkit-scrollbar { width:4px; }
        .shop-items::-webkit-scrollbar-track { background:transparent; }
        .shop-items::-webkit-scrollbar-thumb { background:var(--border); border-radius:10px; }
        .shop-item {
            display:flex; align-items:center; justify-content:space-between; background:#15153a;
            border:1px solid #222255; border-radius:12px; padding:10px 14px;
            cursor:pointer; transition:all 0.2s; gap:10px;
        }
        .shop-item:hover { border-color:var(--accent); background:#1c1c48; }
        .shop-item.locked { opacity:0.45; cursor:not-allowed; }
        .shop-icon { font-size:1.8rem; flex-shrink:0; width:40px; text-align:center; }
        .shop-info { flex:1; min-width:0; }
        .shop-name { font-weight:600; color:#fff; font-size:0.85rem; }
        .shop-desc { font-size:0.7rem; color:var(--text2); }
        .shop-cost { font-weight:700; color:var(--gold); font-size:0.85rem; white-space:nowrap; }
        @media (max-width:400px) {
            .crystal { width:120px; height:120px; }
            .crystal-glow { width:140px; height:140px; }
        }
    </style>
</head>
<body>
<div class="game-container">
    <a href="index.html" class="back-btn">← Home</a>
    <div class="stats-bar">
        <div class="stat-card"><div class="stat-label">💎 Crystals</div><div class="stat-value gold" id="crystalCount">0</div></div>
        <div class="stat-card"><div class="stat-label">⚡ /click</div><div class="stat-value" id="clickPower">1</div></div>
        <div class="stat-card"><div class="stat-label">🔄 /sec</div><div class="stat-value" id="cpsDisplay">0</div></div>
    </div>
    <div class="combo-text" id="comboText">Tap the crystal!</div>
    <div class="combo-bar-container"><div class="combo-bar-fill" id="comboBar"></div></div>
    <div class="crystal-wrapper" id="crystalWrapper">
        <div class="crystal-glow"></div>
        <div class="crystal" id="crystal">
            <svg viewBox="0 0 200 200"><polygon points="100,15 170,70 155,155 100,185 45,155 30,70" fill="url(#crystalGrad)" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/><defs><linearGradient id="crystalGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#c084fc"/><stop offset="50%" stop-color="#a855f7"/><stop offset="100%" stop-color="#6366f1"/></linearGradient></defs></svg>
        </div>
    </div>
    <div class="shop-panel">
        <div class="shop-title">🏪 Upgrade Shop</div>
        <div class="shop-items" id="shopItems"></div>
    </div>
</div>
<script>
    (function() {
        const state = {
            crystals:0, baseClickPower:1, clickPower:1, critChance:0, critMultiplier:2,
            goldenChance:2, goldenMultiplier:10, cps:0, comboCount:0, goldenActive:false,
            upgrades:{}, lastClickTime:0, comboTimer:null, goldenTimer:null
        };
        const upgradeDefs = [
            {id:'click1',name:'Reinforced Pick',icon:'⛏️',desc:'+1 click',baseCost:10,mult:1.8,max:30,effect:()=>{state.baseClickPower+=1}},
            {id:'click2',name:'Crystal Gauntlet',icon:'🧤',desc:'+3 click',baseCost:60,mult:2,max:25,effect:()=>{state.baseClickPower+=3}},
            {id:'auto1',name:'Crystal Sprout',icon:'🌱',desc:'+1/sec',baseCost:50,mult:1.6,max:40,effect:()=>{state.cps+=1}},
            {id:'auto2',name:'Mining Drone',icon:'🤖',desc:'+5/sec',baseCost:300,mult:1.9,max:30,effect:()=>{state.cps+=5}},
            {id:'crit1',name:'Lucky Charm',icon:'🍀',desc:'+4% crit',baseCost:100,mult:2.5,max:15,effect:()=>{state.critChance=Math.min(80,state.critChance+4)}},
            {id:'golden1',name:'Golden Touch',icon:'✨',desc:'+2% golden',baseCost:300,mult:3.5,max:10,effect:()=>{state.goldenChance=Math.min(30,state.goldenChance+2)}},
            {id:'golden2',name:'Midas Amplifier',icon:'👑',desc:'golden x2',baseCost:2000,mult:4,max:5,effect:()=>{state.goldenMultiplier+=10}}
        ];
        upgradeDefs.forEach(d=>state.upgrades[d.id]=0);
        function recalcPower(){ state.clickPower=state.baseClickPower; if(state.goldenActive) state.clickPower*=state.goldenMultiplier; }
        function fmt(n){ return n>=1e15?(n/1e15).toFixed(2)+'Q':n>=1e12?(n/1e12).toFixed(2)+'T':n>=1e9?(n/1e9).toFixed(2)+'B':n>=1e6?(n/1e6).toFixed(2)+'M':n>=1e3?(n/1e3).toFixed(2)+'K':Math.floor(n); }
        function updateUI(){
            document.getElementById('crystalCount').textContent=fmt(state.crystals);
            document.getElementById('clickPower').textContent=fmt(state.clickPower);
            document.getElementById('cpsDisplay').textContent=fmt(state.cps);
            const t=document.getElementById('comboText'), b=document.getElementById('comboBar');
            if(state.comboCount>=5){ t.textContent=`🔥 ${state.comboCount}x COMBO!`; t.style.color='#f59e0b'; }
            else if(state.comboCount>=3){ t.textContent=`✨ ${state.comboCount}x streak`; t.style.color='#c084fc'; }
            else { t.textContent='Tap the crystal!'; t.style.color='#cbd5e1'; }
            b.style.width=Math.min(100,(state.comboCount/20)*100)+'%';
        }
        function getCost(def){ const lvl=state.upgrades[def.id]||0; if(lvl>=def.max) return Infinity; return Math.floor(def.baseCost*Math.pow(def.mult,lvl)); }
        function renderShop(){
            const c=document.getElementById('shopItems');
            c.innerHTML=upgradeDefs.map(def=>{
                const lvl=state.upgrades[def.id]||0, maxed=lvl>=def.max, cost=getCost(def);
                return `<div class="shop-item ${(!(state.crystals>=cost)&&!maxed)?'locked':''}" data-id="${def.id}">
                    <span class="shop-icon">${def.icon}</span><span class="shop-info"><span class="shop-name">${def.name} ${maxed?'(MAX)':'(Lv.'+lvl+')'}</span><span class="shop-desc">${def.desc}</span></span>
                    <span class="shop-cost">${maxed?'MAX':'💎 '+fmt(cost)}</span></div>`;
            }).join('');
            c.querySelectorAll('.shop-item:not(.locked)').forEach(item=>{
                item.addEventListener('click',()=>{
                    const id=item.dataset.id, def=upgradeDefs.find(d=>d.id===id);
                    if(!def||(state.upgrades[id]||0)>=def.max) return;
                    const cost=getCost(def);
                    if(state.crystals>=cost){ state.crystals-=cost; state.upgrades[id]=(state.upgrades[id]||0)+1; def.effect(); recalcPower(); updateUI(); renderShop(); save(); }
                });
            });
        }
        function handleClick(e){
            const now=Date.now();
            if(now-state.lastClickTime<1500) state.comboCount++; else state.comboCount=1;
            state.lastClickTime=now;
            if(state.comboTimer) clearTimeout(state.comboTimer);
            state.comboTimer=setTimeout(()=>{state.comboCount=0; updateUI();},1500);
            let val=state.clickPower;
            if(state.comboCount>=5) val+=Math.floor(state.comboCount*0.5);
            let crit=false,golden=false;
            if(Math.random()*100<state.critChance){ val=Math.floor(val*state.critMultiplier); crit=true; }
            if(!state.goldenActive && Math.random()*100<state.goldenChance){ golden=true; state.goldenActive=true; recalcPower(); if(state.goldenTimer)clearTimeout(state.goldenTimer); state.goldenTimer=setTimeout(()=>{state.goldenActive=false; recalcPower(); updateUI();},8000); }
            if(state.goldenActive && !golden) val=Math.floor(state.baseClickPower*state.goldenMultiplier);
            state.crystals+=val;
            const el=document.createElement('div'); el.className='float-text'; el.style.left=(e.clientX-20)+'px'; el.style.top=(e.clientY-20)+'px'; el.style.color=golden||state.goldenActive?'#f59e0b':crit?'#facc15':'#fff'; el.style.fontSize=(golden||state.goldenActive)?'1.8rem':crit?'1.4rem':'1.2rem'; el.textContent='+'+fmt(val); document.body.appendChild(el); setTimeout(()=>el.remove(),1000);
            updateUI(); save();
        }
        function save(){ localStorage.setItem('crystalTapSave',JSON.stringify({crystals:state.crystals,baseClickPower:state.baseClickPower,critChance:state.critChance,critMultiplier:state.critMultiplier,goldenChance:state.goldenChance,goldenMultiplier:state.goldenMultiplier,cps:state.cps,upgrades:state.upgrades})); }
        function load(){
            try{
                const raw=localStorage.getItem('crystalTapSave');
                if(raw){
                    const d=JSON.parse(raw);
                    state.crystals=d.crystals||0; state.baseClickPower=d.baseClickPower||1;
                    state.critChance=d.critChance||0; state.critMultiplier=d.critMultiplier||2;
                    state.goldenChance=d.goldenChance||2; state.goldenMultiplier=d.goldenMultiplier||10;
                    state.cps=d.cps||0; state.upgrades=d.upgrades||{};
                    upgradeDefs.forEach(def=>{if(!(def.id in state.upgrades)) state.upgrades[def.id]=0;});
                }
            }catch(e){}
            recalcPower();
        }
        const wrapper=document.getElementById('crystalWrapper');
        wrapper.addEventListener('pointerdown',handleClick);
        wrapper.addEventListener('touchstart',e=>{e.preventDefault(); handleClick({clientX:e.touches[0].clientX,clientY:e.touches[0].clientY});},{passive:false});
        document.addEventListener('keydown',e=>{if(e.code==='Space'||e.code==='Enter'){e.preventDefault(); const r=wrapper.getBoundingClientRect(); handleClick({clientX:r.left+r.width/2,clientY:r.top+r.height/2});}});
        setInterval(()=>{if(state.cps>0){state.crystals+=state.cps; updateUI(); save();}},1000);
        load(); updateUI(); renderShop();
    })();
</script>
</body>
</html>
